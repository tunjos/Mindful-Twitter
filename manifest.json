{
  "manifest_version": 3,

  "name": "Mindful Twitter™",
  "description": "Explore Twitter Mindfully...",
  "version": "1.0.2",
  "homepage_url": "https://github.com/tunjos/Mindful-Twitter",

  "action": {
    "default_icon": "images/mindful32.png",
    "default_popup": "index.html",
    "default_title": "Mindful Twitter"
  },
  "icons": {
        "16":  "images/mindful16.png",
        "48":  "images/mindful48.png",
        "128": "images/mindful128.png"
    },
  "content_scripts": [
	{
	    "matches": ["https://www.twitter.com/*", "https://twitter.com/*", "https://www.x.com/*", "https://x.com/*"],
	    "js": ["libs/jquery-3.5.1.min.js", "libs/main.js"],
	    "run_at": "document_end"
	}
  ],
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "https://www.twitter.com/*", "https://twitter.com/*", "https://www.x.com/*", "https://x.com/*"
  ]
}
